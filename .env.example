# ─────────────────────────────────────────────────
# DavaAI v4 — Environment Variables Template
# Copy this to .env and fill in your real values
# NEVER commit .env to git
# ─────────────────────────────────────────────────

# ── Supabase (required) ───────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # service_role key (backend only, keep secret)
SUPABASE_JWT_SECRET=your-jwt-secret  # Supabase dashboard → Settings → API → JWT Settings

# ── Frontend Supabase (required) ─────────────────
REACT_APP_SUPABASE_URL=https://xxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJ...  # anon/public key (safe to expose)

# ── AI Services (required for OCR feature) ───────
GOOGLE_VISION_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── Error tracking (strongly recommended) ─────────
# Get DSN from: https://sentry.io → New Project → FastAPI
# Leave blank to disable (no error in logs, just a warning)
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
ENVIRONMENT=production               # 'production' | 'staging' | 'development'

# ── Backend URL (set in frontend) ─────────────────
REACT_APP_API_URL=https://your-backend.railway.app/api

# ── CORS (production only) ───────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-app.netlify.app
